# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL 18 credentials (used by the db container)
POSTGRES_DB=shortwave
POSTGRES_USER=shortwave
POSTGRES_PASSWORD=change_me_strong_password

# ── Application ───────────────────────────────────────────────────────────────
# Port the app listens on (exposed on host)
PORT=3001

# Public base URL of the service (used for OAuth callback URLs)
# Example: https://shw.link  or  http://localhost:3001
BASE_URL=http://localhost:3001

# Comma-separated list of allowed CORS origins (leave empty to allow all)
CORS_ORIGIN=

# ── Authentication ────────────────────────────────────────────────────────────
# JWT signing secret — use a long random string in production
# Generate: openssl rand -hex 64
JWT_SECRET=replace_with_a_very_long_random_secret_string

# JWT token expiry duration (e.g. 7d, 24h, 30d)
JWT_EXPIRES_IN=7d

# ── Privacy ───────────────────────────────────────────────────────────────────
# Salt used when hashing visitor IPs before storage
# Generate: openssl rand -hex 32
IP_HASH_SALT=replace_with_random_salt_for_ip_hashing

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BASE_URL}/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth (optional) ───────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: ${BASE_URL}/api/auth/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
